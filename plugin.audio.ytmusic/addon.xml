<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.audio.ytmusic"
       name="YTMusic"
       version="1.0.10"
       provider-name="ypoul">
  <requires>
    <import addon="xbmc.python" version="3.0.1"/>
    <import addon="script.module.requests"/>
  </requires>
  <extension point="xbmc.python.pluginsource" library="default.py">
    <provides>audio</provides>
  </extension>
  <extension point="xbmc.service" library="service.py" start="startup"/>

  <extension point="xbmc.addon.metadata">
    <summary lang="en_GB">YouTube Music player for Premium subscribers</summary>
    <description lang="en_GB">Browse and play your YouTube Music library, playlists, liked songs, and more using your YouTube Music Premium account.</description>
    <platform>all</platform>
    <license>MIT</license>
    <assets>
      <icon>icon.png</icon>
    </assets>
  </extension>
</addon>
